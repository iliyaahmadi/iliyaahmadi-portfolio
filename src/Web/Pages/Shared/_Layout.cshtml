<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Iliya Ahmadi</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body class="bg-slate-900 text-white">

<header class="fixed top-0 left-0 w-full z-50 bg-slate-900/80 backdrop-blur border-b border-slate-800">
    <nav class="max-w-5xl mx-auto flex items-center justify-between px-6 py-4">
        <a asp-page="/Index" class="font-bold text-lg tracking-tight">Iliya Ahmadi</a>

        <button id="nav-toggle" class="sm:hidden text-white" aria-label="Toggle navigation">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <ul id="nav-menu" class="hidden sm:flex gap-6 text-sm font-medium">
            <li><a href="/#resume" class="hover:text-sky-400 transition">Resume</a></li>
            <li><a href="/#projects" class="hover:text-sky-400 transition">Projects</a></li>
            <li><a href="/#contact" class="hover:text-sky-400 transition">Contact</a></li>
            <li><a asp-page="/MyLab/Index" class="hover:text-sky-400 transition">MyLab</a></li>
        </ul>
    </nav>

    <ul id="nav-menu-mobile" class="hidden sm:hidden flex-col gap-4 px-6 pb-4 text-sm font-medium">
        <li><a href="/#resume" class="block hover:text-sky-400 transition">Resume</a></li>
        <li><a href="/#projects" class="block hover:text-sky-400 transition">Projects</a></li>
        <li><a href="/#contact" class="block hover:text-sky-400 transition">Contact</a></li>
        <li><a asp-page="/MyLab/Index" class="block hover:text-sky-400 transition">MyLab</a></li>
    </ul>
</header>

<main class="pt-16">
    @RenderBody()
</main>

<footer class="border-t border-slate-800 text-slate-500 text-sm text-center py-6">
    &copy; 2026 Iliya Ahmadi
</footer>

<script>
    document.getElementById('nav-toggle').addEventListener('click', () => {
        document.getElementById('nav-menu-mobile').classList.toggle('hidden');
        document.getElementById('nav-menu-mobile').classList.toggle('flex');
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>